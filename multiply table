# Program to display the multiplication table for a number (e.g., 5)
n = 5
for i in range(1, 11):
    print(f"{n} x {i} = {n * i}")

# Program for a simple countdown timer
import time

seconds = 5
while seconds > 0:
    print(seconds)
    time.sleep(1) # Pauses the program for 1 second
    seconds -= 1
print("Blast off!")
